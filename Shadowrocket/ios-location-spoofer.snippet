#!name=iOS Location Spoofer
#!desc=通过 MITM HTTPS 解密拦截 Apple WiFi/蜂窝定位响应并修改坐标。Quantumult X 重写规则版。
#!homepage=https://github.com/mekos2772/ios-location-spoofer

[rewrite_local]
^https?:\/\/(?:gs-loc(?:-cn)?\.apple\.com|bluedot\.is\.autonavi\.com(?:\.gds\.alibabadns\.com)?)\/clls\/wloc(?:\?.*)?$ url script-response-body https://raw.githubusercontent.com/mekos2772/ios-location-spoofer/main/Shadowrocket/location-spoofer-qx.js

[mitm]
hostname = gs-loc.apple.com, gs-loc-cn.apple.com, bluedot.is.autonavi.com, bluedot.is.autonavi.com.gds.alibabadns.com
